{
  "name": "pr-agent-reviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "PR Agent Reviewer",
  "bin": {
    "pr-agent-review": "./bin/pr-agent-review.js"
  },
  "scripts": {
    "app": "node ./src/server.js",
    "desktop": "electron .",
    "check": "node --check bin/pr-agent-review.js && node --check electron/*.cjs && node --check scripts/*.cjs && node --check src/*.js && node --check src/providers/*.js && node --check src/review/*.js && node --check app/*.js && node --check test/*.test.js && node --check fixtures/*.js",
    "smoke": "electron ./scripts/electron-smoke.cjs",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^43.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "globals": "^17.7.0",
    "knip": "^6.26.0",
    "prettier": "^3.9.5"
  }
}
