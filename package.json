{
  "name": "pr-agent-reviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "PR Agent Reviewer",
  "bin": {
    "pr-agent-review": "./bin/pr-agent-review.js"
  },
  "scripts": {
    "app": "tsc -p tsconfig.app.json && node ./src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.scripts.json && tsc -p tsconfig.app.json",
    "desktop": "npm run build && electron .",
    "smoke": "npm run build && electron ./scripts/electron-smoke.cjs",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.scripts.json --noEmit && tsc -p tsconfig.app.json --noEmit"
  },
  "engines": {
    "node": ">=22.18"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^43.0.0",
    "typescript": "^7.0.2"
  }
}
