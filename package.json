{
  "name": "pr-agent-reviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "PR Agent Reviewer",
  "bin": {
    "pr-agent-review": "./bin/pr-agent-review.js"
  },
  "scripts": {
    "app": "vite build && node ./src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.scripts.json && vite build",
    "desktop": "npm run build && electron .",
    "smoke": "npm run build && electron ./scripts/electron-smoke.cjs",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.scripts.json --noEmit && tsc -p tsconfig.app.json"
  },
  "engines": {
    "node": ">=22.18"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
